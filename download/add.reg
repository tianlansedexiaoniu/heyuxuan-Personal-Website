Windows Registry Editor Version 5.00

[HKEY_CLASSES_ROOT\cmd.exe]
"URL Protocol"=""
[HKEY_CLASSES_ROOT\cmd.exe\shell\open\command]
@="cmd.exe /k"

[HKEY_CLASSES_ROOT\regedit.exe]
"URL Protocol"=""
[HKEY_CLASSES_ROOT\regedit.exe\shell\open\command]
@="regedit.exe"

[HKEY_CLASSES_ROOT\taskmgr.exe]
"URL Protocol"=""
[HKEY_CLASSES_ROOT\taskmgr.exe\shell\open\command]
@="taskmgr.exe"

[HKEY_CLASSES_ROOT\explorer.exe]
"URL Protocol"=""
[HKEY_CLASSES_ROOT\explorer.exe\shell\open\command]
@="explorer.exe"

[HKEY_CLASSES_ROOT\compmgmt.msc]
"URL Protocol"=""
[HKEY_CLASSES_ROOT\compmgmt.msc\shell\open\command]
@="mmc.exe compmgmt.msc"

[HKEY_CLASSES_ROOT\notepad]
"URL Protocol"=""
[HKEY_CLASSES_ROOT\notepad\shell\open\command]
@="notepad.exe"

[HKEY_CLASSES_ROOT\iscsicpl.exe]
"URL Protocol"=""
[HKEY_CLASSES_ROOT\iscsicpl.exe\shell\open\command]
@="%windir%\\system32\\iscsicpl.exe"

[HKEY_CLASSES_ROOT\write]
"URL Protocol"=""
[HKEY_CLASSES_ROOT\write\shell\open\command]
@="write.exe"

[HKEY_CLASSES_ROOT\odbcad32.exe]
"URL Protocol"=""
[HKEY_CLASSES_ROOT\odbcad32.exe\shell\open\command]
@="%windir%\\syswow64\\odbcad32.exe"

[HKEY_CLASSES_ROOT\mstsc]
"URL Protocol"=""
[HKEY_CLASSES_ROOT\mstsc\shell\open\command]
@="mstsc.exe"

[HKEY_CLASSES_ROOT\cleanmgr]
