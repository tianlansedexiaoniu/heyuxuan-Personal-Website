[HKEY_CLASSES_ROOT\services.msc]
"URL Protocol"=""
[HKEY_CLASSES_ROOT\services.msc\shell\open\command]
@="mmc.exe services.msc"

[HKEY_CLASSES_ROOT\WF.msc]
"URL Protocol"=""
[HKEY_CLASSES_ROOT\WF.msc\shell\open\command]
@="mmc.exe %windir%\\system32\\WF.msc"

