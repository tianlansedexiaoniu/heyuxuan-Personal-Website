"URL Protocol"=""
[HKEY_CLASSES_ROOT\calc\shell\open\command]
@="calc.exe"

[HKEY_CLASSES_ROOT\msinfo32]
"URL Protocol"=""
[HKEY_CLASSES_ROOT\msinfo32\shell\open\command]
@="msinfo32.exe"

[HKEY_CLASSES_ROOT\gpedit.msc]
"URL Protocol"=""
[HKEY_CLASSES_ROOT\gpedit.msc\shell\open\command]
@="mmc.exe gpedit.msc"

[HKEY_CLASSES_ROOT\perfmon]
"URL Protocol"=""
[HKEY_CLASSES_ROOT\perfmon\shell\open\command]
@="perfmon.exe"

[HKEY_CLASSES_ROOT\resmon]
"URL Protocol"=""
[HKEY_CLASSES_ROOT\resmon\shell\open\command]
@="resmon.exe"

[HKEY_CLASSES_ROOT\control]
"URL Protocol"=""
[HKEY_CLASSES_ROOT\control\shell\open\command]
@="control.exe"

[HKEY_CLASSES_ROOT\mspaint]
"URL Protocol"=""
[HKEY_CLASSES_ROOT\mspaint\shell\open\command]
@="mspaint.exe"

[HKEY_CLASSES_ROOT\powershell]
"URL Protocol"=""
[HKEY_CLASSES_ROOT\powershell\shell\open\command]
@="powershell.exe -NoExit"

[HKEY_CLASSES_ROOT\powershell_ise]
"URL Protocol"=""
[HKEY_CLASSES_ROOT\powershell_ise\shell\open\command]
@="powershell_ise.exe"

[HKEY_CLASSES_ROOT\msedge]
"URL Protocol"=""
[HKEY_CLASSES_ROOT\msedge\shell\open\command]
@="msedge.exe"

[HKEY_CLASSES_ROOT\shutdown_s]
"URL Protocol"=""
[HKEY_CLASSES_ROOT\shutdown_s\shell\open\command]
@="shutdown.exe -s -t 0"

[HKEY_CLASSES_ROOT\shutdown_r]
"URL Protocol"=""
[HKEY_CLASSES_ROOT\shutdown_r\shell\open\command]
@="shutdown.exe -r -t 0"

[HKEY_CLASSES_ROOT\sleep]
"URL Protocol"=""
[HKEY_CLASSES_ROOT\sleep\shell\open\command]
@="rundll32.exe powrprof.dll,SetSuspendState 0,1,0"

[HKEY_CLASSES_ROOT\shutdown_l]
"URL Protocol"=""
[HKEY_CLASSES_ROOT\shutdown_l\shell\open\command]
@="shutdown.exe -l"

[HKEY_CLASSES_ROOT\restart_explorer]
"URL Protocol"=""
[HKEY_CLASSES_ROOT\restart_explorer\shell\open\command]
@="cmd.exe /c taskkill /f /im explorer.exe && start explorer.exe"

[HKEY_CURRENT_USER\Software\Microsoft\Windows\CurrentVersion\Internet Settings\ZoneMap\Domains\github.io\tianlansedexiaoniu]
